    "svelte": "^4.2.0",
    "vite": "^5.4.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "dayjs": "^1.11.0",
    "express": "^5.2.1",
    "ws": "^8.18.0"
  }
}
